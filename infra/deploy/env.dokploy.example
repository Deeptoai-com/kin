# ============================================================================
# Kin — Dokploy environment example  (OPTIONAL / demo path)
# ----------------------------------------------------------------------------
# Dokploy is a SECONDARY route. The supported production paths are the VPS
# one-command installer and the Cloudflare-tunnel stack. Use Dokploy only if
# you specifically want it (e.g. an existing Dokploy panel). Full guide:
#   docs/deployment/dokploy.md
#
# This lists ONLY what docker-compose.dokploy.yml actually needs.
#
# ⚠️  DO NOT set DATABASE_URL or ANTHROPIC_API_KEY.
#     • The compose derives DATABASE_URL from POSTGRES_* (single source of truth);
#       setting it separately drifts from POSTGRES_PASSWORD → migrate fails 28P01.
#     • ARK auth is Bearer via ANTHROPIC_AUTH_TOKEN; setting ANTHROPIC_API_KEY
#       makes the SDK use x-api-key → ARK returns 401.
# ============================================================================

# ── Domain ──────────────────────────────────────────────────────────────────
APP_HOSTNAME=kin.example.com
APP_NAME=kin
# APP_NAME_SANITIZED MUST be unique per deploy on a shared host: volume names are
# global (${APP_NAME_SANITIZED}-data); a collision reuses another stack's data
# volume + its old password → migrate 28P01.
APP_NAME_SANITIZED=kin

# ── Images (GHCR, public, multi-arch — Dokploy PULLS, never builds: SSR build OOMs) ──
APP_IMAGE=ghcr.io/deeptoai-com/kin/app
APP_TAG=latest          # if :latest is not published yet, pin a real <git-sha> tag
PARSER_IMAGE=ghcr.io/deeptoai-com/kin/parser
PARSER_TAG=latest

# ── Datastores (generate: `openssl rand -hex 24` / `-hex 32`; avoid URL-special chars) ──
POSTGRES_USER=kin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=kin
MINIO_ROOT_USER=kinminio
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=kin
MEILI_MASTER_KEY=CHANGE_ME
BETTER_AUTH_SECRET=CHANGE_ME

# ── Model gateway (ARK / Volcengine example — set to your gateway + models) ──
ANTHROPIC_AUTH_TOKEN=CHANGE_ME
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
# All four aliases must resolve to real models on your gateway, or the SDK falls
# back to hard-coded Anthropic model names that don't exist on ARK.
ANTHROPIC_MODEL=glm-5.2
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.2
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2
ANTHROPIC_DEFAULT_HAIKU_MODEL=doubao-seed-2.0-lite
CLAUDE_CODE_SUBAGENT_MODEL=glm-5.2

# ── Feature flags (demo-safe defaults) ──────────────────────────────────────
RAG_ENABLED=false       # the parser sidecar is not in this compose → keep RAG off
UPDATER_TOKEN=          # empty = online auto-update OFF (Dokploy owns the stack lifecycle)
BULLMQ_PREFIX=kin       # app and worker must share the same prefix
ENABLE_STRUCTURED_OUTPUTS=false
