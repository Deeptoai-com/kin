# Cloudflare Tunnel ingress for the OxyGenie "Path C / tunnel" deploy.
#
# Copy this to config.yml, then fill `tunnel:` with your tunnel id (and write
# credentials.json) — both are derived from your tunnel token. See README.md /
# docs/deployment/tunnel.md, step 2:
#   cp config.yml.example config.yml
#   ...decode token -> credentials.json + sed REPLACE_WITH_TUNNEL_ID -> <your id>
#
# Everything (oxygenie.cc + every *.oxygenie.cc preview subdomain) is forwarded to the
# bundled Traefik, which does the Host-based routing (app vs preview-<id>). Cloudflare
# terminates TLS at the edge, so the tunnel→Traefik hop is plain HTTP.
#
# Replace oxygenie.cc with your own domain in both hostnames below.
tunnel: REPLACE_WITH_TUNNEL_ID
credentials-file: /etc/cloudflared/credentials.json
ingress:
  - hostname: oxygenie.cc
    service: http://traefik:80
  - hostname: "*.oxygenie.cc"
    service: http://traefik:80
  - service: http_status:404
